# PANTHEON_BFF_AUTH_STUB="true; staging/prod stay strict JWT/OIDC."
VITE_BFF_BASE_URL="https://pantheon-lupin-dev-bff.35.201.239.38.sslip.io"
# Dev console operator token. Roles (2nd segment) drive write authorization on the
# dev BFF (permissive stub auth). operator alone is read-only → approve/decide/etc.
# buttons 403. Granting the full operator role set lets those flows run. Real
# mutations stay gated by VITE_BFF_REAL_WRITES=false (dry-run) + per-action MFA/
# confirm-token gates, so the publicly-readable bundle token cannot mutate dev state.
VITE_BFF_DEV_BEARER_TOKEN="pantheon-dev-browser:viewer"
VITE_BFF_MODE="live"
# Strict live mode: on a live-BFF transport failure, surface the error (degraded
# state) instead of silently substituting in-process mock seed data. Prevents the
# dev console from showing fake pools/personas that look real when the BFF is down.
VITE_BFF_FALLBACK="strict"
