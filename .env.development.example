# Pantheon lupin dev environment — live BFF wiring.
# Copy to `.env.development` (or `.env.local`) when you want the FE to talk
# to the lupin dev backend. Vitest always pins itself to mock regardless of
# this file (see src/lib/bff-v1/client.ts detectMode()).

VITE_BFF_MODE=live
VITE_BFF_BASE_URL=https://pantheon-lupin-dev-bff.34.81.75.241.sslip.io

# auto = silent mock fallback on transport failure (good for demo/dev UX)
# strict = surface transport failure as typed BffError (good for integration tests)
VITE_BFF_FALLBACK=auto
VITE_BFF_REAL_WRITES=false
