# BFF Contract v1 mode switch.
#   mock  — default; serves in-process seed via the mock adapter registry.
#   live  — POST/GET against VITE_BFF_BASE_URL; on transport failure auto-falls
#           back to mock and shows a top-of-app banner with a retry button.
VITE_BFF_MODE=live
