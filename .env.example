# BFF Contract v1 mode switch.
#   mock  — DEFAULT. Serves in-process seed via the mock adapter registry.
#   live  — GET/POST against VITE_BFF_BASE_URL. Use VITE_BFF_FALLBACK=auto
#           for hybrid dev fallback, or strict for real integration checks.
VITE_BFF_MODE=mock

# Live BFF base URL (only read when VITE_BFF_MODE=live).
# Shared dev URL: `.env.dev.example`.
# Lupin dev URL: `.env.development.example`.
# Staging-live URL: `.env.staging-live.example`.
VITE_BFF_BASE_URL=

# Live transport fallback policy (only read when VITE_BFF_MODE=live).
#   auto    — DEFAULT. On 5xx / network failure, fall back to mock and show
#             the LiveBffBanner with a retry button.
#   strict  — Never fall back. Live transport failures surface as typed
#             BffError to callers (use this for integration testing where
#             silent mock fallback hides real bugs).
VITE_BFF_FALLBACK=auto

# Live write guard. Keep false until operator auth, approval evidence,
# confirm-token, and two-man signing are verified against the target BFF.
VITE_BFF_REAL_WRITES=false

# Auth/session access:
# - Browser cookie sessions are supported through fetch(credentials="include").
# - Optional dev bearer token keys are read from sessionStorage first, then
#   localStorage: pantheon.bff.bearerToken or legacy pantheon_operator_token.
# - VITE_BFF_DEV_BEARER_TOKEN is compiled into public JavaScript. Leave it
#   empty or use a dev-only viewer identity such as pantheon-dev-browser:viewer.
#   Never place operator/admin roles or assistant.kernel capabilities here.
# - Operator actions use an interactive cookie/sessionStorage credential; they
#   are never provided through VITE_* build variables.
# - Optional tenant keys: pantheon.bff.tenantId or legacy pantheon_tenant_id.
VITE_BFF_DEV_BEARER_TOKEN=

# 2026-05-20 Management revamp §8 — NL Console (Phase 1).
# HARD RULE: Phase 1 = fixed_mock only. NO direct Lovable AI Gateway call.
# Strict mode = error, never silent fallback.
VITE_MANAGEMENT_NL_PROVIDER=fixed_mock
VITE_MANAGEMENT_NL_GATEWAY_ENABLED=false
