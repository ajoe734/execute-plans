# Integration test runner environment (Playwright + probe scripts + CI).
# Not read by Vite — copy values to your shell or pass via CI secrets.

# Pantheon dev frontend under test.
PANTHEON_FE_BASE_URL=https://pantheon-lupin-dev-fe.35.201.239.38.sslip.io

# Live BFF under test (lupin dev).
PANTHEON_BFF_BASE_URL=https://pantheon-lupin-dev-bff.35.201.239.38.sslip.io

# Strict integration mode (no mock fallback). Required for release gate.
VITE_BFF_MODE=live
VITE_BFF_FALLBACK=strict
PANTHEON_E2E_STRICT=1

# Where probe scripts write evidence markdown.
PANTHEON_AUDIT_OUT_DIR=.lovable/audits

# Substring detected in hosted JS bundle to flag obsolete BFF URL.
PANTHEON_OLD_BFF_URL=pantheon-ai-system-front-dev

# Bearer for authenticated smoke. Inject from secret store; never commit.
PANTHEON_BFF_SMOKE_BEARER_TOKEN=
