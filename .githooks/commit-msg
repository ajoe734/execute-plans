#!/usr/bin/env bash
# Enforce execute-plans commit conventions documented in
# docs/conventions/GIT_WORKFLOW.md §5 (ported from pantheon).
#
# Enable per clone with:  git config core.hooksPath .githooks
#
# Bypass envvar: PANTHEON_TRAILER_CHECK_DISABLED=1

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
MSG_FILE="$1"

python3 "$ROOT_DIR/scripts/git/check_commit_trailers.py" --message-file "$MSG_FILE"

staged=$(git diff --cached --name-only --diff-filter=ACMR)
if [[ -n "$staged" ]]; then
  echo "$staged" | xargs python3 "$ROOT_DIR/scripts/git/check_generated_files.py"
fi
