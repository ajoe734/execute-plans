{
  "branch_workflow": {
    "enabled": true,
    "task_branch_prefix": "task/",
    "publish_branch_prefix": "publish/",
    "release_tag_prefix": "release/",
    "prod_tag_prefix": "prod/",
    "archive_tag_prefix": "archive/",
    "dev_branch": "dev",
    "main_branch": "main",
    "nightly_publish": {
      "enabled": true,
      "cron_utc": "0 * * * *",
      "version_format": "vYYYY.MM.DD.N",
      "skip_if_no_new_commits": true
    },
    "promote": {
      "trigger": "publish_soak",
      "soak_days": 1,
      "regression_label_prefix": "regression/",
      "block_labels": ["hold-promote", "regression"],
      "promote_pr_label": "auto-promote",
      "auto_merge": true
    },
    "task_pr": {
      "auto_merge": true,
      "require_commit_trailers": ["LLM-Agent", "Task-ID", "Reviewer"],
      "subject_prefix_required": true,
      "required_status_checks": [
        "Commit trailers",
        "Generated files guard",
        "Smoke acceptance"
      ],
      "max_open_hours": 24
    }
  }
}
